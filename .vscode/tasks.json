{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Auto pull on open",
      "type": "shell",
      "command": "git pull --rebase --autostash",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "close": true,
        "showReuseMessage": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    },
    {
      "label": "Auto pull watcher",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/auto-pull.sh",
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "close": false,
        "showReuseMessage": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    }
  ]
}
